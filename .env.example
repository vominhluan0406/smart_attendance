# Server
PORT=8080
ENV=development

# Database (local SQLite — used when TURSO_URL is empty)
DB_PATH=data/smart_attendance.db

# Turso (remote libSQL — set both to enable, overrides DB_PATH)
TURSO_URL=
TURSO_TOKEN=

# JWT
JWT_SECRET=change-me-to-a-strong-random-string
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_HOURS=168

# Rate Limiting
RATE_LIMIT_PER_MIN=10

# Microsoft OAuth (optional — leave empty to disable)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8080/auth/oauth/microsoft/callback
MICROSOFT_TENANT_ID=common
